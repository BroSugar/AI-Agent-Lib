# ──────────────────────────────────────────────
# PAgent-Lib 环境变量模板
# 复制为 .env 并填入你的实际值
# ──────────────────────────────────────────────

# LLM 模型配置
LLM_MODEL=gemma4:e4b
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7

# MCP Server 配置
MCP_SERVER_URL=http://localhost:8080/mcp/sse
MCP_TOKEN=
MCP_STREAMABLE_URL=http://localhost:8080/mcp

# 阿里云 DashScope
ALI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# AWS Bedrock
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
